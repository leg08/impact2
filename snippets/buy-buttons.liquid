{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
BUY BUTTONS
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign variant_picker_block = section.blocks | where: 'type', 'variant_picker' | first -%}

{%- assign recipient_feature_active = false -%}

{%- if product.gift_card? and show_gift_card_recipient -%}
  {%- assign recipient_feature_active = true -%}
  {%- assign show_payment_button = false -%}
{%- endif -%}

{%- liquid
  assign hide_flocage = false
  assign product_type_downcase = product.type | downcase
  assign product_title_downcase = product.title | downcase

  if product_type_downcase contains 'chaussure' or product_type_downcase contains 'crampon'
    assign hide_flocage = true
  endif

  if product_title_downcase contains 'chaussure' or product_title_downcase contains 'crampon'
    assign hide_flocage = true
  endif
-%}

{%- unless hide_flocage -%}
  {%- for tag in product.tags -%}
    {%- assign tag_downcase = tag | downcase -%}

    {%- if tag_downcase contains 'chaussure' or tag_downcase contains 'crampon' -%}
      {%- assign hide_flocage = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endunless -%}

{%- assign flocage_price = 490 -%}
{%- assign selected_variant = product.selected_or_first_available_variant -%}

{%- form 'product', product, is: 'product-form', id: form_id -%}
  <input type="hidden" {% if variant_picker_block != blank %}disabled{% endif %} name="id" value="{{ selected_variant.id }}">

  {%- assign button_disabled = false -%}
  {%- assign button_size = button_size | default: 'xl' -%}

  {%- if selected_variant == nil -%}
    {%- capture button_content -%}{{ 'product.general.unavailable_button' | t }}{%- endcapture -%}
    {%- assign button_disabled = true -%}
  {%- elsif selected_variant.available -%}
    {%- if product.template_suffix contains 'pre-order' -%}
      {%- capture button_content -%}{{ 'product.general.pre_order_button' | t }}{%- endcapture -%}
    {%- else -%}
      {%- capture button_content -%}{{ 'product.general.add_to_cart_button' | t }}{%- endcapture -%}
    {%- endif -%}
  {%- else -%}
    {%- capture button_content -%}{{ 'product.general.sold_out_button' | t }}{%- endcapture -%}
    {%- assign button_disabled = true -%}
  {%- endif -%}

  <div class="v-stack gap-4">
    {%- if recipient_feature_active -%}
      <gift-card-recipient class="gift-card-recipient v-stack gap-3">
        {%- assign checkbox_label = 'gift_card.recipient.checkbox' | t -%}
        {%- render 'checkbox', label: checkbox_label, name: 'properties[__shopify_send_gift_card_to_recipient]' -%}

        <div class="gift-card-recipient__fields" hidden>
          <div class="fieldset">
            {%- liquid
              assign recipient_email_label = 'gift_card.recipient.email_label' | t
              render 'input', type: 'email', label: recipient_email_label, name: 'properties[Recipient email]', value: form.email, required: true

              assign recipient_name_label = 'gift_card.recipient.name_label' | t
              render 'input', label: recipient_name_label, name: 'properties[Recipient name]', value: form.name

              assign send_on_label = 'gift_card.recipient.send_on_label' | t
              render 'input', type: 'date', label: send_on_label, name: 'properties[Send on]', value: form.send_on, pattern: '\d{4}-\d{2}-\d{2}'
              render 'input', type: 'hidden', name: 'properties[__shopify_offset]'

              assign message_label = 'gift_card.recipient.message_label' | t
              render 'input', label: message_label, name: 'properties[Message]', value: form.message, multiline: 3, maxlength: 200, show_max_characters_count: true
            -%}
          </div>
        </div>
      </gift-card-recipient>
    {%- endif -%}

    {%- unless hide_flocage -%}
      <style>
        .flocage-option {
          padding: 1rem;
          border: 1px solid rgba(0, 0, 0, 0.12);
          border-radius: 12px;
        }

        .flocage-option__header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 1rem;
          margin-bottom: 0.75rem;
        }

        .flocage-option__title {
          margin: 0;
          font-size: 1rem;
          font-weight: 600;
        }

        .flocage-option__price {
          font-size: 0.95rem;
          font-weight: 600;
          white-space: nowrap;
        }

        .flocage-option__toggle {
          position: absolute;
          opacity: 0;
          pointer-events: none;
        }

        .flocage-option__switch-row {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 1rem;
        }

        .flocage-option__switch-label {
          font-size: 0.95rem;
          font-weight: 500;
        }

        .po-switch {
          position: relative;
          display: inline-block;
          width: 52px;
          height: 30px;
          flex: 0 0 auto;
          cursor: pointer;
        }

        .po-switch-slider {
          position: absolute;
          inset: 0;
          background-color: #d4d4d8;
          transition: 0.3s ease;
        }

        .po-switch-slider:before {
          position: absolute;
          content: "";
          height: 22px;
          width: 22px;
          left: 4px;
          bottom: 4px;
          background-color: #ffffff;
          transition: 0.3s ease;
        }

        .po-switch-round {
          border-radius: 999px;
        }

        .po-switch-round:before {
          border-radius: 50%;
        }

        .flocage-option__toggle:checked + .flocage-option__switch-row .po-switch-slider {
          background-color: #0f766e;
        }

        .flocage-option__toggle:checked + .flocage-option__switch-row .po-switch-slider:before {
          transform: translateX(22px);
        }

        .flocage-option__content {
          display: none;
          margin-top: 0.9rem;
        }

        .flocage-option__toggle:checked ~ .flocage-option__content {
          display: block;
        }

        .flocage-option__label {
          display: block;
          margin-bottom: 0.45rem;
          font-size: 0.9rem;
          font-weight: 500;
        }

        .flocage-option__input {
          width: 100%;
          min-height: 46px;
          padding: 0.8rem 0.95rem;
          border: 1px solid #d4d4d8;
          border-radius: 10px;
          background: #ffffff;
          color: #111111;
          box-sizing: border-box;
        }

        .flocage-option__summary {
          margin-top: 0.9rem;
          padding-top: 0.9rem;
          border-top: 1px solid rgba(0, 0, 0, 0.08);
        }

        .flocage-option__summary-line {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 1rem;
          font-size: 0.92rem;
        }

        .flocage-option__summary-line + .flocage-option__summary-line {
          margin-top: 0.35rem;
        }

        .flocage-option__summary-line strong {
          font-weight: 600;
        }
      </style>

      <div
        class="flocage-option"
        data-flocage-root
        data-base-price="{{ selected_variant.price | default: 0 }}"
        data-flocage-price="{{ flocage_price }}"
      >
        <div class="flocage-option__header">
          <p class="flocage-option__title">Flocage</p>
          <span class="flocage-option__price">+ {{ flocage_price | money }}</span>
        </div>

        <input
          type="checkbox"
          id="{{ form_id }}-flocage-toggle"
          class="flocage-option__toggle"
          name="properties[Flocage]"
          value="Oui"
          data-flocage-toggle
        >

        <div class="flocage-option__switch-row">
          <span class="flocage-option__switch-label">Ajouter un flocage</span>

          <label class="po-switch" for="{{ form_id }}-flocage-toggle" aria-label="Ajouter un flocage">
            <span class="po-switch-slider po-switch-round"></span>
          </label>
        </div>

        <div class="flocage-option__content">
          <label for="{{ form_id }}-flocage-text" class="flocage-option__label">Texte du flocage</label>
          <input
            type="text"
            id="{{ form_id }}-flocage-text"
            class="flocage-option__input"
            name="properties[Texte flocage]"
            placeholder="Ex: MBAPPE 10"
            maxlength="24"
            disabled
            data-flocage-text
          >

          <div class="flocage-option__summary">
            <div class="flocage-option__summary-line" data-flocage-base-line>
              <span>Prix du produit</span>
              <strong>{{ selected_variant.price | default: 0 | money }}</strong>
            </div>

            <div class="flocage-option__summary-line" data-flocage-total-line hidden>
              <span>Prix avec flocage</span>
              <strong>{{ selected_variant.price | default: 0 | plus: flocage_price | money }}</strong>
            </div>
          </div>
        </div>
      </div>
    {%- endunless -%}

    <buy-buttons class="buy-buttons {% if show_payment_button %}buy-buttons--multiple{% endif %}" template="{{ product.template_suffix | escape }}" form="{{ form_id }}">
      {%- render 'button', content: button_content, type: 'submit', size: button_size, disabled: button_disabled, secondary: show_payment_button, subdued: button_disabled, background: atc_button_background, text_color: atc_button_text_color -%}

      {%- if show_payment_button -%}
        {{- form | payment_button -}}

        <style>
          #{{ form_id }} .shopify-payment-button {
            {%- unless selected_variant.available -%}
              display: none;
            {%- endunless -%}

            {%- if payment_button_background != blank and payment_button_background != 'rgba(0,0,0,0)' -%}
              --button-background: {{ payment_button_background.rgb }};
            {%- endif -%}

            {%- if payment_button_text_color != blank and payment_button_text_color != 'rgba(0,0,0,0)' -%}
              --button-text-color: {{ payment_button_text_color.rgb }};
            {%- endif -%}
          }
        </style>
      {%- endif -%}
    </buy-buttons>
  </div>
{%- endform -%}

<script>
  (function() {
    function formatMoneyFromShopify(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === "function") {
        return window.Shopify.formatMoney(cents, {{ shop.money_format | json }});
      }

      return (cents / 100).toFixed(2).replace(".", ",") + " EUR";
    }

    function getMainPriceContainer() {
      return document.querySelector(".product-info__price .price-list")
        || document.querySelector(".product-info__price")
        || document.querySelector(".price-list");
    }

    function getPriceTargets(container) {
      if (!container) {
        return [];
      }

      var candidates = container.querySelectorAll(".price, .price-list__current, .price-item--regular, .text-lg, sale-price, compare-at-price");

      if (candidates.length > 0) {
        return Array.prototype.slice.call(candidates);
      }

      return [container];
    }

    function syncFlocage(root) {
      var toggle = root.querySelector("[data-flocage-toggle]");
      var textInput = root.querySelector("[data-flocage-text]");
      var baseLine = root.querySelector("[data-flocage-base-line]");
      var totalLine = root.querySelector("[data-flocage-total-line]");
      var mainPriceContainer = getMainPriceContainer();

      if (!toggle) {
        return;
      }

      var checked = toggle.checked;
      var basePrice = parseInt(root.getAttribute("data-base-price") || "0", 10);
      var flocagePrice = parseInt(root.getAttribute("data-flocage-price") || "0", 10);
      var totalPrice = checked ? basePrice + flocagePrice : basePrice;

      if (textInput) {
        textInput.disabled = !checked;

        if (!checked) {
          textInput.value = "";
        }
      }

      if (baseLine) {
        baseLine.hidden = checked;
      }

      if (totalLine) {
        totalLine.hidden = !checked;
        var strong = totalLine.querySelector("strong");

        if (strong) {
          strong.textContent = formatMoneyFromShopify(totalPrice);
        }
      }

      var priceTargets = getPriceTargets(mainPriceContainer);

      priceTargets.forEach(function(target) {
        if (!target.hasAttribute("data-original-price-html")) {
          target.setAttribute("data-original-price-html", target.innerHTML);
        }

        if (checked) {
          target.textContent = formatMoneyFromShopify(totalPrice);
        } else {
          target.innerHTML = target.getAttribute("data-original-price-html");
        }
      });
    }

    if (!window.flocageVisualPriceBound) {
      window.flocageVisualPriceBound = true;

      document.addEventListener("change", function(event) {
        if (!event.target.matches("[data-flocage-toggle]")) {
          return;
        }

        var root = event.target.closest("[data-flocage-root]");

        if (root) {
          syncFlocage(root);
        }
      });
    }

    document.querySelectorAll("[data-flocage-root]").forEach(syncFlocage);
  })();
</script>