ery-cta-text {\n    font-size: 11px;\n    color: #000000;\n    margin: 0;\n    line-height: 1.3;\n  }\n\n  .delivery-cta-highlight {\n    color: #000000;\n    font-weight: 600;\n  }\n\n  @media (max-width: 768px) {\n    .delivery-estimator {\n      padding: 14px;\n      margin: 10px 0;\n    }\n\n    .delivery-header {\n      margin-bottom: 10px;\n      gap: 6px;\n    }\n\n    .delivery-title {\n      font-size: 14px;\n    }\n\n    .delivery-content {\n      grid-template-columns: 1fr;\n      gap: 10px;\n    }\n\n    .delivery-date {\n      font-size: 16px;\n    }\n\n    .countdown-section {\n      padding: 10px;\n      gap: 6px;\n    }\n\n    .countdown-timer {\n      gap: 3px;\n    }\n\n    .countdown-value {\n      font-size: 16px;\n    }\n\n    .countdown-unit {\n      min-width: 34px;\n    }\n\n    .countdown-separator {\n      font-size: 14px;\n    }\n\n    .urgency-message {\n      margin-top: 6px;\n      min-height: 16px;\n      font-size: 10px;\n    }\n\n    .delivery-cta {\n      margin-top: 8px;\n      padding-top: 8px;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .delivery-estimator {\n      padding: 12px;\n      margin: 8px 0;\n    }\n\n    .delivery-header {\n      margin-bottom: 8px;\n    }\n\n    .delivery-icon {\n      width: 22px;\n      height: 22px;\n      font-size: 12px;\n    }\n\n    .delivery-title {\n      font-size: 13px;\n    }\n\n    .delivery-date {\n      font-size: 15px;\n    }\n\n    .delivery-date-detail {\n      font-size: 10px;\n    }\n\n    .countdown-section {\n      padding: 10px;\n    }\n\n    .countdown-value {\n      font-size: 15px;\n    }\n\n    .countdown-unit {\n      min-width: 32px;\n    }\n\n    .countdown-separator {\n      font-size: 13px;\n    }\n\n    .delivery-cta-text {\n      font-size: 10px;\n    }\n\n    .urgency-message {\n      font-size: 9px;\n      min-height: 16px;\n    }\n  }\n</style>\n\n<div class=\"delivery-estimator\">\n  <div class=\"delivery-header\">\n    <div class=\"delivery-icon\">📦</div>\n    <h3 class=\"delivery-title\">Livraison Express</h3>\n  </div>\n\n  <div class=\"delivery-content\">\n    <div class=\"delivery-date-section\">\n      <span class=\"delivery-label\">Livraison estimee</span>\n      <div class=\"delivery-date\" id=\"deliveryDate\">-</div>\n      <div class=\"delivery-date-detail\" id=\"deliveryDetail\">Commandez maintenant</div>\n    </div>\n\n    <div class=\"countdown-section\">\n      <div class=\"countdown-label\">Temps restant</div>\n      <div class=\"countdown-timer\">\n        <div class=\"countdown-unit\">\n          <div class=\"countdown-value\" id=\"hours\">00</div>\n          <div class=\"countdown-unit-label\">h</div>\n        </div>\n        <div class=\"countdown-separator\">:</div>\n        <div class=\"countdown-unit\">\n          <div class=\"countdown-value\" id=\"minutes\">00</div>\n          <div class=\"countdown-unit-label\">m</div>\n        </div>\n        <div class=\"countdown-separator\">:</div>\n        <div class=\"countdown-unit\">\n          <div class=\"countdown-value\" id=\"seconds\">00</div>\n          <div class=\"countdown-unit-label\">s</div>\n        </div>\n      </div>\n      <div class=\"urgency-message\" id=\"urgencyMessage\">avant changement de delai</div>\n    </div>\n  </div>\n\n  <div class=\"delivery-cta\">\n    <p class=\"delivery-cta-text\">✓ Livraison gratuite • <span class=\"delivery-cta-highlight\">Securisee</span></p>\n  </div>\n</div>\n\n<script>\n  function updateDeliveryEstimate() {\n    const now = new Date();\n    const currentHour = now.getHours();\n\n    const cutoffHour = 14;\n    const deliveryDate = new Date(now);\n\n    if (currentHour < cutoffHour) {\n      deliveryDate.setDate(deliveryDate.getDate() + 1);\n    } else {\n      deliveryDate.setDate(deliveryDate.getDate() + 2);\n    }\n\n    deliveryDate.setHours(10, 0, 0, 0);\n\n    const options = { weekday: 'long', month: 'long', day: 'numeric' };\n    const formattedDate = deliveryDate.toLocaleDateString('fr-FR', options);\n    const capitalizedDate = formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1);\n\n    document.getElementById('deliveryDate').textContent = capitalizedDate;\n\n    let nextCutoff = new Date(now);\n    nextCutoff.setHours(cutoffHour, 0, 0, 0);\n\n    if (now >= nextCutoff) {\n      nextCutoff.setDate(nextCutoff.getDate() + 1);\n    }\n\n    function updateCountdown() {\n      const nowTick = new Date();\n      const timeRemaining = nextCutoff - nowTick;\n\n      if (timeRemaining <= 0) {\n        document.getElementById('hours').textContent = '00';\n        document.getElementById('minutes').textContent = '00';\n        document.getElementById('seconds').textContent = '00';\n        document.getElementById('urgencyMessage').textContent = 'Delai mis a jour';\n        return;\n      }\n\n      const hours = Math.floor(timeRemaining / (1000 * 60 * 60));\n      const minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));\n      const seconds = Math.floor((timeRemaining % (1000 * 60)) / 1000);\n\n      document.getElementById('hours').textContent = String(hours).padStart(2, '0');\n      document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');\n      document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');\n\n      const urgencyElement = document.getElementById('urgencyMessage');\n      if (hours === 0 && minutes < 30) {\n        urgencyElement.textContent = 'Commandez vite';\n      } else {\n        urgencyElement.textContent = 'avant changement de delai';\n      }\n    }\n\n    updateCountdown();\n    setInterval(updateCountdown, 1000);\n\n    const daysUntil = Math.ceil((deliveryDate - now) / (1000 * 60 * 60 * 24));\n    if (daysUntil === 1) {\n      document.getElementById('deliveryDetail').textContent = 'Demain a 10h';\n    } else if (daysUntil === 2) {\n      document.getElementById('deliveryDetail').textContent = 'Dans 2 jours';\n    } else {\n      document.getElementById('deliveryDetail').textContent = 'Dans ' + daysUntil + ' jours';\n    }\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', updateDeliveryEstimate);\n  } else {\n    updateDeliveryEstimate();\n  }\n</script>"
